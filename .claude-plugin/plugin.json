{
  "name": "hsp",
  "version": "0.14.0",
  "description": "Harness Server Protocol: one MCP plugin that selects the right LSP for the workspace",
  "author": {
    "name": "holo-q"
  },
  "repository": "https://github.com/holo-q/hsp",
  "license": "MIT",
  "keywords": ["hsp", "lsp", "language-server", "python", "csharp", "mcp"],
  "lspServers": {
    "ty": {
      "command": "ty",
      "args": ["server"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    },
    "basedpyright": {
      "command": "basedpyright-langserver",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".py": "python",
        ".pyi": "python"
      }
    },
    "csharp-ls": {
      "command": "csharp-ls",
      "args": [],
      "extensionToLanguage": {
        ".cs": "csharp"
      }
    }
  },
  "mcpServers": {
    "hsp": {
      "command": "uvx",
      "args": ["--refresh", "--from", "git+https://github.com/holo-q/hsp", "hsp"],
      "env": {
        "HSP_AUTO_PROFILES": "1"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "LSP",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --refresh --from git+https://github.com/holo-q/hsp hsp-redirect-hook"
          }
        ]
      }
    ]
  }
}

